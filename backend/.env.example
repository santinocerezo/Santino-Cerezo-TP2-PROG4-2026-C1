# ===== Servidor =====
# Puerto local. En Render se asigna automáticamente (no hace falta tocarlo).
PORT=3000

# URL del frontend permitida por CORS. Para varias, separar con coma.
FRONTEND_URL=http://localhost:4200

# ===== MongoDB Atlas =====
# Reemplazá USUARIO, PASSWORD y el host por tu cadena de conexión real.
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/red-social?retryWrites=true&w=majority

# ===== Cloudinary (Dashboard -> Account Details) =====
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
